{
  "compilerOptions": {
    // Environment setup & latest features
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true, // Array indexing safety (e.g., safe array access)
    "noImplicitOverride": true,
    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    // "types": [
    //   "bun"
    // ],
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "esModuleInterop": true,
    "outDir": "dist",
    // Additional safety options
    "noImplicitAny": true, // Prevents implicit 'any' type
    "strictNullChecks": true, // Ensures null and undefined are checked
    "noImplicitThis": true, // Ensures 'this' is typed explicitly
    "alwaysStrict": true // Enforces 'use strict' mode for JavaScript
  },
  "include": [
    "src/**/*"
  ]
}
